elif mode == "📊 Product Trend Analysis":

    if not st.session_state.db:
        st.info("No feedback data available.")
    else:
        df = pd.DataFrame(st.session_state.db)

        tdf = pd.DataFrame({
            "Course": list(st.session_state.p.keys()),
            "Average Rating": [
                round(info["ts"]/info["c"],1)
                for info in st.session_state.p.values()
            ]
        })

        st.plotly_chart(
            px.area(tdf, x="Course", y="Average Rating",
                    color="Course", markers=True,
                    title="Course Rating Trend"),
            use_container_width=True
        )

        st.dataframe(df)
